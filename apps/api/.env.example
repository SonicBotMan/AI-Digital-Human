# --- Project ---
PROJECT_NAME=AI Digital Human
VERSION=0.1.0
DEBUG=false

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/digital_human

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=face_embeddings

# --- LLM Provider Selection ---
LLM_PROVIDER=glm

# --- GLM (智谱AI) ---
GLM_API_KEY=your-glm-api-key
GLM_MODEL=glm-4-flash

# --- MiniMax ---
MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_GROUP_ID=your-group-id
MINIMAX_MODEL=MiniMax-Text-01

# --- OpenAI ---
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o

# --- LLM通用配置 ---
DEFAULT_LLM_MODEL=glm-4-flash
MAX_TOKENS=4096
TEMPERATURE=0.7

# --- Vision ---
VISION_PROVIDER=glm
VISION_MODEL=glm-4v-flash

# --- InsightFace ---
INSIGHTFACE_MODEL_ROOT=./models

# --- Whisper ---
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu

# --- CORS ---
CORS_ORIGINS=["*"]

# --- JWT Auth ---
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
