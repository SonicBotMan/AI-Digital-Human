# =============================================================================
# AI Digital Human - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.default .env
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Provider Configuration (GLM recommended for Chinese support)
# -----------------------------------------------------------------------------
LLM_PROVIDER=glm

# GLM (智谱AI) - Recommended for Chinese support
# Get your API key from: https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key_here
GLM_MODEL=glm-4-flash

# MiniMax (海螺AI) - Alternative option
# Get your API key from: https://platform.minimax.chat/
# MINIMAX_API_KEY=your_minimax_api_key_here
# MINIMAX_GROUP_ID=your_minimax_group_id_here
# MINIMAX_MODEL=MiniMax-Text-01

# OpenAI (Optional - requires VPN in China)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# Vision Model Configuration
# -----------------------------------------------------------------------------
VISION_PROVIDER=glm
VISION_MODEL=glm-4v-flash

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# For production (4GB server), use SQLite:
DATABASE_URL=sqlite+aiosqlite:///data/digitalhuman.db

# For development with PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/digital_human

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Qdrant Configuration (for vector storage)
# -----------------------------------------------------------------------------
# Use local mode for production (no separate container needed)
QDRANT_MODE=local
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Use server mode for development (requires Qdrant container)
# QDRANT_MODE=server
# QDRANT_HOST=qdrant
# QDRANT_PORT=6333

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
DEBUG=false
PROJECT_NAME=AI Digital Human

# -----------------------------------------------------------------------------
# CORS (allow all origins for development)
# -----------------------------------------------------------------------------
CORS_ORIGINS=["*"]